<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#110D2B">

    <!-- TOP-RIGHT decorative circle -->
    <View
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="-90dp"
        android:layout_marginEnd="-90dp"
        android:background="@drawable/bg_blob_top"/>

    <!-- BOTTOM-LEFT decorative circle -->
    <View
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_alignParentBottom="true"
        android:layout_alignParentStart="true"
        android:layout_marginBottom="-60dp"
        android:layout_marginStart="-60dp"
        android:background="@drawable/bg_blob_bottom"/>

    <!-- Centered scroll container -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingTop="60dp"
            android:paddingBottom="40dp">

            <!-- ── HEADER ── -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="36dp">

                <!-- Logo circle with lock emoji substitute -->
                <TextView
                    android:layout_width="68dp"
                    android:layout_height="68dp"
                    android:gravity="center"
                    android:text="🔒"
                    android:textSize="28sp"
                    android:background="@drawable/bg_logo_circle"
                    android:layout_gravity="center"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Welcome Back"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:letterSpacing="0.01"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Sign in to continue"
                    android:textSize="14sp"
                    android:textColor="#99FFFFFF"/>

            </LinearLayout>

            <!-- ── GLASS CARD ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_glass_card"
                android:paddingStart="22dp"
                android:paddingEnd="22dp"
                android:paddingTop="28dp"
                android:paddingBottom="28dp">

                <!-- USERNAME label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="USERNAME"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#AAFFFFFF"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="8dp"/>

                <!-- Username field -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="20dp">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_input_field"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:layout_marginStart="14dp"
                        android:text="👤"
                        android:textSize="16sp"/>

                    <EditText
                        android:id="@+id/username"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:paddingStart="46dp"
                        android:paddingEnd="14dp"
                        android:hint="Enter your username"
                        android:textColorHint="#88FFFFFF"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:background="@android:color/transparent"
                        android:inputType="text"
                        android:singleLine="true"/>
                </FrameLayout>

                <!-- PASSWORD label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PASSWORD"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#AAFFFFFF"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="8dp"/>

                <!-- Password field -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="10dp">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_input_field"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:layout_marginStart="14dp"
                        android:text="🔑"
                        android:textSize="16sp"/>

                    <EditText
                        android:id="@+id/password"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:paddingStart="46dp"
                        android:paddingEnd="48dp"
                        android:hint="Enter your password"
                        android:textColorHint="#88FFFFFF"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:background="@android:color/transparent"
                        android:inputType="textPassword"
                        android:singleLine="true"/>

                    <!-- Eye toggle -->
                    <TextView
                        android:id="@+id/togglePassword"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical|end"
                        android:layout_marginEnd="14dp"
                        android:text="👁"
                        android:textSize="16sp"
                        android:clickable="true"
                        android:focusable="true"/>
                </FrameLayout>

                <!-- Forgot password -->
                <TextView
                    android:id="@+id/forgotPassword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_marginBottom="24dp"
                    android:text="Forgot password?"
                    android:textSize="13sp"
                    android:textColor="#FFD580"
                    android:clickable="true"
                    android:focusable="true"/>

                <!-- SIGN IN button -->
                <Button
                    android:id="@+id/loginBtn"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="SIGN IN"
                    android:textSize="14sp"
                    android:letterSpacing="0.15"
                    android:textStyle="bold"
                    android:textColor="#1A0533"
                    android:background="@drawable/bg_login_button"
                    android:stateListAnimator="@null"/>

            </LinearLayout>

            <!-- ── SIGN UP ROW ── -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Don't have an account?  "
                    android:textSize="14sp"
                    android:textColor="#88FFFFFF"/>

                <TextView
                    android:id="@+id/signUpLink"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sign Up"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FFD580"
                    android:clickable="true"
                    android:focusable="true"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</RelativeLayout>